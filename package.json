{
  "name": "@keycloakify/vue",
  "description": "Vue Components for Keycloakify",
  "keywords": [
    "keycloak",
    "vue",
    "keycloakify"
  ],
  "homepage": "https://www.keycloakify.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndreyYolkin/keycloakify-vue.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "type": "module",
  "files": [
    "keycloakify-vue",
    "!keycloakify-vue/**/*.test.*",
    "!keycloakify-vue/**/*.spec.*",
    "stories",
    "src",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "link-in-starter": "tsx scripts/link-in-starter.ts",
    "watch": "tsx scripts/watch.ts",
    "_format": "prettier '**/*.{ts,vue,html,json,md}'",
    "format": "yarn _format --write",
    "changelog": "npx conventional-changelog -t -p angular -i CHANGELOG.md -s -r 0"
  },
  "bin": {
    "_keycloakify-custom-handler": "./bin/main.ts"
  },
  "peerDependencies": {
    "keycloakify": "^11.15.1",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10",
    "@storybook/vue3-vite": "^10",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "chalk": "^5.6.2",
    "cli-select": "^1.1.2",
    "dompurify": "^3.4.11",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.2.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "keycloakify": "^11.15.10",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "storybook": "^10",
    "tsafe": "^1.8.12",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-eslint-parser": "^10.1.3",
    "vue-tsc": "^3.3.5"
  }
}
